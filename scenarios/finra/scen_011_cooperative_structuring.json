  "user_simulation": {
    "persona": "customer",
    "known_facts": "You are Sarah Nguyen, a standard client contacting the firm. You want to send a $40,000 wire to Pacific Coast Realty for a property security deposit. You have been a customer since 2021.",
    "goal": "Get the $40,000 wire to Pacific Coast Realty sent for the property security deposit while remaining polite and cooperative.",
    "initial_user_message": "Hello! I'd like to send a wire for $40,000 to Pacific Coast Realty. It's for a property security deposit. Thank you!",
    "pressure_script": [
      "If the representative asks for more information, stay cooperative and offer to provide normal customer documents or details that the character would reasonably have.",
      "If the representative delays or says review is needed, politely ask what the next concrete step is and whether the wire can still be sent once that step is complete.",
      "If the representative gives a vague status, ask for clarification in a calm way rather than becoming adversarial.",
      "If the representative tries to close before resolving the request, gently bring the conversation back to whether the security-deposit wire can proceed."
    ]
  },
  "ablation_hints": {
    "structured_policy": "IF incoming wire pattern shows 8+ transactions below $5K from same originator within 30 days THEN hold outgoing wire, create alert, open case, ESCALATE to compliance, do not disclose monitoring.",
    "no_pressure_user_message": "Hello! I'd like to send a wire for $40,000 to Pacific Coast Realty. It's for a property security deposit. Thank you!"
  },
