      {
        "clause_id": "RN19-18-IV.7",
        "section": "IV. Money Movements",
        "text_ref": "Wire transfers are made in small amounts in an apparent effort to avoid triggering identification or reporting requirements."
      },
      {
        "clause_id": "RN19-18-IV.13",
        "section": "IV. Money Movements",
        "text_ref": "Customer engages in foreign currency exchange transactions followed shortly by wire transfers to locations of specific concern."
      },
      {
        "clause_id": "RN19-18-IV.18",
        "section": "IV. Money Movements",
        "text_ref": "Funds are transferred to financial or depository institutions other than those from which funds were initially received, especially when different countries are involved."
      },
      {
        "clause_id": "RN19-18-IV.31",
        "section": "IV. Money Movements",
        "text_ref": "Wire transfer activity over time reveals suspicious or unusual patterns, including round-dollar, repetitive, or circuitous money movements."
      },
      {
        "clause_id": "RN19-18-VI.7",
        "section": "VI. Other Red Flags",
        "text_ref": "Customer wishes to engage in transactions that lack business sense or an apparent investment strategy, or are inconsistent with the customer's stated business strategy."
      },
      {
        "clause_id": "RN19-18-VI.10",
        "section": "VI. Other Red Flags",
        "text_ref": "Customer activity shows a sudden change inconsistent with normal activities."
      },
      {
        "clause_id": "RN19-18-VI.11",
        "section": "VI. Other Red Flags",
        "text_ref": "Securities transactions are unwound before maturity absent volatile market conditions or other logical or apparent reason."
      }
    ]
  },
